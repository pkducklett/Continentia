<elements>
	<info>
		<name>Fortuitous Soul</name>
        <update version="0.0.1">
			<!-- Update Notes: -->
		    	<description>The Fortuitous Soul Sub-class from Continentia.</description>
		    	<author url="https://github.com/pkducklett/">Corie Welch and the Amazing Dicey Dudes</author>
